<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nueva Task</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Nueva tarea</h1>

      <form class="form" method="post" action="/tasks">
        <label class="label" for="title">Title</label>
        <input class="input" id="title" name="title" type="text" maxlength="255" required />

        <label class="label" for="description">Descripción</label>
        <textarea class="input" id="description" name="description" rows="5"></textarea>

        <div class="row">
          <a class="btn secondary" href="/tasks">Volver</a>
          <button class="btn" type="submit">Guardar</button>
        </div>
      </form>
    </main>
  </body>
</html>

