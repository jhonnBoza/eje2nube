<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Task</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="container">
      <h1>Editar tarea</h1>

      <form class="form" method="post" action="/tasks/<%= task.id %>/update">
        <label class="label" for="title">Title</label>
        <input
          class="input"
          id="title"
          name="title"
          type="text"
          maxlength="255"
          required
          value="<%= task.title %>"
        />

        <label class="label" for="description">Descripción</label>
        <textarea class="input" id="description" name="description" rows="5"><%= task.description ? task.description : "" %></textarea>

        <div class="row">
          <a class="btn secondary" href="/tasks">Volver</a>
          <button class="btn" type="submit">Actualizar</button>
        </div>
      </form>
    </main>
  </body>
</html>

